# ==========================================
# 1. APPLICATION & SERVER
# ==========================================
ENV="development"
FRONTEND_URL="http://localhost:3000"

# CORS origins (comma separated)
# Note: Do not put localhost dev links here! If ENV="development", localhost:3000, 5173, and 8000 
# are automatically whitelisted. Keeping them out of this variable prevents you from 
# accidentally leaving localhost exposed to Cross-Origin attacks in production.
CORS_ORIGINS="https://myapp.example.com,https://admin.myapp.example.com"

# Admin User Email (this user will automatically be granted the 'admin' role)
ADMIN_EMAIL="admin@example.com"

# Log retention (days)
LOG_RETENTION_DAYS=28

# Account retention (days to keep soft-deleted accounts before permanent deletion)
ACCOUNT_RETENTION_DAYS=30

# ==========================================
# 2. DATABASES & CACHE
# ==========================================
# SQL Database (PostgreSQL recommended)
DB_ASYNC_URL="postgresql+asyncpg://postgres:password@db:5432/auth_db"

# Cache Database
# Used for Rate Limiting, JWT Blacklisting, and API Response Caching.
# Supports redis://, memcached://, etc. Defaults to Redis. 
CACHE_URL="redis://redis:6379/0"

# Celery Background Tasks
CELERY_BROKER_URL="redis://redis:6379/1"
CELERY_RESULT_BACKEND="redis://redis:6379/2"

# ==========================================
# 3. SECURITY & AUTHENTICATION
# ==========================================
SESSION_SECRET="your-32-byte-secret-for-oauth-sessions"

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"

JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----"

# Token Configuration
TOKEN_ACCESS_TOKEN_LIFETIME_MINUTES=15
TOKEN_REFRESH_TOKEN_LIFETIME_DAYS=7

# Verification Settings
VERIFICATION_OTP_EXPIRATION_SECONDS=300
VERIFICATION_OTP_RESEND_WINDOW_SECONDS=900
VERIFICATION_OTP_MAX_ATTEMPTS=5
VERIFICATION_PASSWORD_RESET_EXPIRY_SECONDS=900

# ==========================================
# 4. OAUTH PROVIDERS
# ==========================================
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ==========================================
# 5. EMAIL CONFIGURATION (Resend)
# ==========================================
EMAIL_API_KEY="re_your_api_key_here"
EMAIL_FROM="onboarding@resend.dev"
# Choose a theme: modern, minimal, elegant
EMAIL_TEMPLATE_NAME="modern"

# ==========================================
# 6. RATE LIMITING
# ==========================================
# Rate Limiting (Gets Enabled at ENV="production")
# Note: If deploying behind a reverse proxy (ALB, Nginx, Cloudflare),
# you MUST run Uvicorn with --proxy-headers and --forwarded-allow-ips="*"
# so that the real client IP is securely extracted for rate limiting.
RATE_LIMIT_REFRESH_RATE_LIMIT="30/minute"
RATE_LIMIT_LOGIN_RATE_LIMIT="5/minute"
RATE_LIMIT_DEFAULT_RATE_LIMIT="60/minute"
