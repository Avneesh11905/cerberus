############################################################
# APPLICATION
############################################################

ENV=developement

FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001

ADMIN_EMAIL=superadmin@example.com

LOG_RETENTION_DAYS=28
ACCOUNT_RETENTION_DAYS=30

############################################################
# DATABASE
############################################################

POSTGRES_DB=postgres
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD="your_postgres_password"

DB_ASYNC_URL=postgresql+asyncpg://postgres_user:your_postgres_password@cerb-postgres:52193/postgres

############################################################
# REDIS
############################################################

REDIS_USER=default
REDIS_PASSWORD=your_redis_password

CACHE_URL=redis://default:your_redis_password@cerb-redis:52192/0
CELERY_BROKER_URL=redis://default:your_redis_password@cerb-redis:52192/1
CELERY_RESULT_BACKEND=redis://default:your_redis_password@cerb-redis:52192/2

############################################################
# SECURITY
############################################################

SESSION_SECRET="your_32_byte_session_secret"
ENCRYPTION_KEY="your_encryption_key_base64_url_safe"

############################################################
# JWT
############################################################

JWT_PRIVATE_KEY_PATH=/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/keys/jwt_public.pem

# Note: RSA Keys should be generated using `uv run backend/scripts/generate_keys.py`
# They will be saved directly into `backend/keys/` and read from there by the application.

TOKEN_ACCESS_TOKEN_LIFETIME_MINUTES=15
TOKEN_REFRESH_TOKEN_LIFETIME_DAYS=7

############################################################
# OTP
############################################################

VERIFICATION_OTP_EXPIRATION_SECONDS=300
VERIFICATION_OTP_RESEND_WINDOW_SECONDS=900
VERIFICATION_OTP_MAX_ATTEMPTS=5
VERIFICATION_PASSWORD_RESET_EXPIRY_SECONDS=900

############################################################
# GOOGLE OAUTH
############################################################

GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

############################################################
# GITHUB OAUTH
############################################################

GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"

############################################################
# EMAIL
############################################################

EMAIL_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@example.com
EMAIL_TEMPLATE_NAME=modern

############################################################
# RATE LIMITING
############################################################

RATE_LIMIT_REFRESH_RATE_LIMIT=30/minute
RATE_LIMIT_LOGIN_RATE_LIMIT=5/minute
RATE_LIMIT_DEFAULT_RATE_LIMIT=60/minute

############################################################
# FRONTEND
############################################################

ALLOWED_HOSTS=localhost
